DHI inline patch (cassandra 4.0): drop transitive Hadoop dependency tree

Removes the hadoop-core and hadoop-minicluster pulls that drag in vulnerable
transitive commons-collections, commons-beanutils, jasper, mina-core. None
of those code paths are exercised by core cassandra (CQL, gossip, nodetool).

Upstream Cassandra source: https://github.com/apache/cassandra/blob/cassandra-4.0.19/build.xml
Build wiring: image/cassandra/patch/cassandra-4-mvn-dependencies.json (DHI)

diff --git a/build.xml b/build.xml
index 0d7a567a91..72ed21d024 100644
--- a/build.xml
+++ b/build.xml
@@ -598,11 +598,21 @@
             <exclusion groupId="ant" artifactId="ant"/>
             <exclusion groupId="junit" artifactId="junit"/>
             <exclusion groupId="org.codehaus.jackson" artifactId="jackson-mapper-asl"/>
+            <exclusion groupId="commons-collections" artifactId="commons-collections"/>
+            <exclusion groupId="commons-beanutils" artifactId="commons-beanutils"/>
+            <exclusion groupId="tomcat" artifactId="jasper-runtime"/>
+            <exclusion groupId="tomcat" artifactId="jasper-compiler"/>
+            <exclusion groupId="com.sun.jersey" artifactId="jersey-server"/>
+            <exclusion groupId="com.sun.jersey" artifactId="jersey-core"/>
+            <exclusion groupId="commons-net" artifactId="commons-net"/>
             <exclusion groupId="org.slf4j" artifactId="slf4j-api"/>
           </dependency>
           <dependency groupId="org.apache.hadoop" artifactId="hadoop-minicluster" version="1.0.3" scope="provided">
             <exclusion groupId="asm" artifactId="asm"/> <!-- this is the outdated version 3.1 -->
             <exclusion groupId="org.slf4j" artifactId="slf4j-api"/>
             <exclusion groupId="org.codehaus.jackson" artifactId="jackson-mapper-asl"/>
+            <exclusion groupId="org.apache.hadoop" artifactId="hadoop-test"/>
+            <exclusion groupId="com.sun.jersey" artifactId="jersey-server"/>
+            <exclusion groupId="com.sun.jersey" artifactId="jersey-core"/>
           </dependency>
           <dependency groupId="net.java.dev.jna" artifactId="jna" version="5.6.0"/>
